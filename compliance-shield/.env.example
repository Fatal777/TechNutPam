# ComplianceShield Environment Variables
# Copy this to .env and fill in your API keys

# Google Gemini API - Code analysis, compliance checking, auto-remediation
GEMINI_API_KEY=

# CrustData API - Real-time compliance intelligence (web search + news search)
# Get your token at https://app.crustdata.com/
CRUSTDATA_API_TOKEN=

# SafeDep - Dependency malware/vulnerability scanning
SAFEDEP_API_KEY=
SAFEDEP_TENANT_ID=

# Unsiloed AI - Parse compliance PDFs into structured rules
UNSILOED_API_KEY=

# Razorpay - Billing for SaaS plans (test mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
