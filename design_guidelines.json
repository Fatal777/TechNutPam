{
  "project_name": "ComplianceShield",
  "theme": {
    "default": "light",
    "toggle_strategy": "class-based",
    "colors": {
      "primary": {
        "DEFAULT": "#2563EB",
        "foreground": "#FFFFFF",
        "hover": "#1D4ED8",
        "active": "#1E40AF"
      },
      "secondary": {
        "DEFAULT": "#F1F5F9",
        "foreground": "#0F172A",
        "hover": "#E2E8F0"
      },
      "accent": {
        "success": "#10B981",
        "warning": "#F59E0B",
        "error": "#EF4444",
        "info": "#3B82F6"
      },
      "background": {
        "light": "#F8FAFC",
        "dark": "#0B1121",
        "surface_light": "#FFFFFF",
        "surface_dark": "#1E293B"
      },
      "text": {
        "primary_light": "#0F172A",
        "secondary_light": "#475569",
        "primary_dark": "#F8FAFC",
        "secondary_dark": "#94A3B8"
      },
      "border": {
        "light": "#E2E8F0",
        "dark": "#334155"
      }
    },
    "typography": {
      "font_family": {
        "heading": "Outfit, sans-serif",
        "body": "Inter, sans-serif",
        "code": "JetBrains Mono, monospace"
      },
      "scale": {
        "h1": "text-5xl md:text-7xl font-bold tracking-tight",
        "h2": "text-4xl md:text-5xl font-semibold tracking-tight",
        "h3": "text-2xl md:text-3xl font-semibold",
        "body": "text-base md:text-lg leading-relaxed",
        "small": "text-sm text-muted-foreground"
      }
    },
    "spacing": {
      "container_padding": "p-6 md:p-12 lg:p-16",
      "section_gap": "gap-12 md:gap-24",
      "element_gap": "gap-4 md:gap-6"
    },
    "radius": {
      "default": "rounded-lg",
      "card": "rounded-xl",
      "button": "rounded-md"
    }
  },
  "layout_strategies": {
    "landing_page": {
      "hero": {
        "type": "bento_grid",
        "grid_cols": "grid-cols-1 md:grid-cols-12",
        "elements": [
          { "type": "headline", "span": "col-span-full md:col-span-7", "vibe": "bold_typographic" },
          { "type": "visual_abstract", "span": "col-span-full md:col-span-5", "vibe": "glass_card_overlay" }
        ]
      },
      "features": {
        "type": "zigzag_list",
        "gap": "gap-20"
      }
    },
    "dashboard": {
      "structure": "sidebar_layout",
      "sidebar": {
        "width": "w-64",
        "state": "collapsible",
        "theme": "dark_sidebar_light_content"
      },
      "grid": {
        "type": "dense_metrics",
        "cols": "grid-cols-1 md:grid-cols-3 lg:grid-cols-4",
        "gap": "gap-6"
      }
    }
  },
  "components": {
    "buttons": {
      "primary": "bg-primary text-primary-foreground hover:bg-primary/90 shadow-lg hover:shadow-primary/20 transition-all active:scale-95",
      "secondary": "bg-secondary text-secondary-foreground hover:bg-secondary/80",
      "ghost": "hover:bg-accent hover:text-accent-foreground",
      "outline": "border border-input bg-background hover:bg-accent hover:text-accent-foreground"
    },
    "cards": {
      "base": "bg-card text-card-foreground rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow",
      "glass": "bg-white/70 dark:bg-black/60 backdrop-blur-xl border border-white/20 shadow-lg",
      "highlight": "border-l-4 border-l-primary bg-primary/5"
    },
    "badges": {
      "success": "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 border border-green-200 dark:border-green-800",
      "warning": "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400 border border-amber-200 dark:border-amber-800",
      "error": "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400 border border-red-200 dark:border-red-800",
      "neutral": "bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-400"
    }
  },
  "assets": {
    "icons": {
      "library": "lucide-react",
      "style": "stroke-width-2"
    },
    "images": {
      "hero_bg": "https://images.unsplash.com/photo-1759661881353-5b9cc55e1cf4?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2NzV8MHwxfHNlYXJjaHwxfHxjeWJlciUyMHNlY3VyaXR5JTIwbmV0d29yayUyMGFic3RyYWN0JTIwYmx1ZXxlbnwwfHx8fDE3NzM0Nzk0MDJ8MA&ixlib=rb-4.1.0&q=85",
      "developer_working": "https://images.unsplash.com/photo-1770159116807-9b2a7bb82294?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NDk1Nzl8MHwxfHNlYXJjaHw0fHxkZXZlbG9wZXIlMjBjb2RpbmclMjBsYXB0b3AlMjBtb2Rlcm4lMjBvZmZpY2V8ZW58MHx8fHwxNzczNDc5Mzk0fDA&ixlib=rb-4.1.0&q=85",
      "server_room": "https://images.unsplash.com/photo-1744868562210-fffb7fa882d9?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA1OTV8MHwxfHNlYXJjaHwxfHxtb2Rlcm4lMjBzZXJ2ZXIlMjByb29tJTIwZGF0YSUyMGNlbnRlciUyMGJsdWUlMjBsaWdodHN8ZW58MHx8fHwxNzczNDc5Mzk2fDA&ixlib=rb-4.1.0&q=85"
    }
  },
  "motion": {
    "library": "framer-motion",
    "transitions": {
      "page_load": {
        "initial": { "opacity": 0, "y": 20 },
        "animate": { "opacity": 1, "y": 0 },
        "exit": { "opacity": 0, "y": -20 },
        "transition": { "duration": 0.4, "ease": "easeOut" }
      },
      "hover_lift": {
        "whileHover": { "y": -4 },
        "transition": { "type": "spring", "stiffness": 300 }
      }
    }
  },
  "instructions_to_main_agent": [
    "Install 'lucide-react', 'framer-motion', 'clsx', 'tailwind-merge' immediately.",
    "Use 'Outfit' font for all Headings (h1-h3) and 'Inter' for body. Import them via Google Fonts or Fontsource.",
    "Implement the Theme Toggle early. It must persist state.",
    "For the Dashboard, use a Sidebar Layout. The sidebar should be dark in both themes for contrast (or adapting deeply).",
    "The 'Scan Detail View' should use a 'Sheet' or 'Drawer' component from Shadcn/UI for context preservation.",
    "Pricing cards must highlight the 'Pro' tier with a 'Popular' badge and a slight scale transform.",
    "Reports table must use 'Table' component with clear headers and row hover states.",
    "Ensure all interactive elements have 'data-testid' attributes."
  ],
  "universal_guidelines": [
    "Do not use generic gradients. Use subtle noise or grain if texture is needed.",
    "Avoid centering everything. Use asymmetry for the Landing Page.",
    "Use 'gap-8' or 'gap-12' for section spacing to allow breathing room.",
    "Glassmorphism should be high-quality: 'backdrop-blur-xl' with a thin 'border-white/20'.",
    "Inputs and Forms should not have gray backgrounds by default; use white/transparent with borders.",
    "Do not ask user for clarification. Use these guidelines as the source of truth."
  ]
}